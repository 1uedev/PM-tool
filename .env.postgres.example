# PostgreSQL environment — copy to .env.postgres and fill in real values.
# Used by scripts/smoke-postgres.mjs and docker-compose.postgres.yml.

DATABASE_URL="postgresql://pmcopilot:pmcopilot@localhost:5433/pmcopilot_test"

NEXTAUTH_SECRET="replace-with-a-secure-random-string"
NEXTAUTH_URL="http://localhost:3000"

# AI (optional — smoke test does not require a real key)
AI_PROVIDER="disabled"
